{
  "pack_name": "barrel_inside_texture_pack",
  "description": "Interior texture pack for a hollow sci-fi industrial barrel: one wraparound inner wall strip and one circular interior floor/base.",
  "source": "Generated from the open empty barrel concept image.",
  "notes": [
    "The wall albedo has been processed to blend the left and right edges for a cleaner cylindrical wrap.",
    "Normal, roughness, metallic, height and AO maps are generated approximations from the albedo texture rather than baked from a true 3D high-poly mesh.",
    "ORM maps use red=ambient occlusion, green=roughness, blue=metallic.",
    "The floor albedo alpha version includes transparent corners for the circular UV island; the square version is included for engines that prefer opaque textures."
  ],
  "recommended_mapping": {
    "wall": {
      "mesh_part": "inside cylindrical wall",
      "uv": "wrap horizontally around cylinder; tile/wrap U axis once; V axis vertical",
